# OFT Sentinel — backend environment
# Copy to .env at the repo root (backend/.env is a symlink to it):  cp .env.example .env
# Contracts deployment has its own file: contracts/.env.example

# ── Required ──────────────────────────────────────────────────────────────────

# Signer that pays for attest()/alert() txs on Mantle Sepolia (chainId 5003).
# Fund it with test MNT: https://faucet.sepolia.mantle.xyz
SENTINEL_PRIVATE_KEY=

# Deployed attestation contracts on Mantle Sepolia. Use the live ones below,
# or deploy your own (see contracts/): npm run deploy:testnet
AUDIT_REGISTRY_ADDRESS=0xf07d24dbd1fe21645a0489a94bae2c99d7e0e80b
ALERT_BUS_ADDRESS=0x350dc422bb2979684573409f229679fed383b2e5

# Dune Analytics — builds the OFT watch list (all-time ≥$1M volume on Mantle).
# Free key: https://dune.com/settings/api
DUNE_API_KEY=
MANTLE_OFT_QUERY_ID=7638642
MANTLE_SENTINEL_QUERY_ID=7664779

# Etherscan v2 (free tier) — corridor discovery via PeerSet event logs
# (1 call replaces a 170-EID peers() sweep per OFT) and last-resort eth_call
# fallback when all Mantle RPCs fail. Without it the Sentinel still works,
# but every poll brute-forces all known V2 EVM EIDs per OFT.
# Free key: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# DeepSeek — Security Copilot chat + AI audit report narrative.
# NOT in the security path: scoring/verdicts/attestations are fully
# deterministic; unset key = deterministic fallback text.
DEEPSEEK_API_KEY=

# Telegram alerts. Public channel gets every drift alert; team map DMs
# specific OFT teams. Values: numeric chat id or @channel_name.
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLIC_ALERT_CHAT_ID=
# Backward-compatible fallback for the public alert channel.
TELEGRAM_ALERT_CHAT_ID=
# Per-OFT contacts keyed by ticker or address; arrays or comma-separated.
# Example: {"cmETH":["123456789","@cmeth_ops"],"0x1111…1111":"@oft_team"}
TELEGRAM_TEAM_ALERTS_JSON=

# ── Defaults (override only if needed) ────────────────────────────────────────

PORT=3001
# Monitored chain: Mantle mainnet (LayerZero EID 30181)
MANTLE_CHAIN_ID=5000
# Attestation chain: Mantle Sepolia
SENTINEL_RPC=https://rpc.sepolia.mantle.xyz
SENTINEL_CHAIN_ID=5003
# ERC-8004 agent token id embedded in every attestation (live Sentinel = 120)
SENTINEL_AGENT_ID=120
# Where sentinel-state.json + score-history.jsonl live.
# Local default: backend/data — on Railway set DATA_DIR=/data (persistent volume).
# DATA_DIR=/data
# Comma-separated allowed origins for the API (production).
# CORS_ORIGINS=https://oft-sentinel.netlify.app
