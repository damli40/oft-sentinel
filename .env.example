# Circle developer-controlled wallets
# 1. Create account at https://console.circle.com
# 2. Register entity secret: https://developers.circle.com/wallets/dev-controlled/register-entity-secret
# 3. Run: cd backend && npx tsx src/setup/create-circle-wallet.ts
# 4. Paste CIRCLE_SERVICE_WALLET_ID and CIRCLE_SERVICE_WALLET_ADDRESS from script output below
# 5. Fund the wallet at https://faucet.circle.com (select Arc Testnet)
CIRCLE_API_KEY=
ENTITY_SECRET=
CIRCLE_SERVICE_WALLET_ID=
CIRCLE_SERVICE_WALLET_ADDRESS=

# APIs
DEEPSEEK_API_KEY=sk-
ETHERSCAN_API_KEY=

# Dune — Mantle OFT leaderboard dashboard data (https://dune.com/queries/7638642)
DUNE_API_KEY=
MANTLE_OFT_QUERY_ID=7638642

# Telegram
TELEGRAM_BOT_TOKEN=
# Public channel/chat that receives every Sentinel drift alert.
# Use a numeric chat id or @public_channel_name.
TELEGRAM_PUBLIC_ALERT_CHAT_ID=
# Backward-compatible fallback for the public alert channel.
TELEGRAM_ALERT_CHAT_ID=
# OFT-team-specific Telegram contacts, keyed by ticker or OFT address.
# Values can be arrays or comma-separated strings.
# Example: {"cmETH":["123456789","@cmeth_ops"],"0x1111111111111111111111111111111111111111":"@oft_team"}
TELEGRAM_TEAM_ALERTS_JSON=

# Server
PORT=3001
VITE_API_BASE=http://localhost:3001
